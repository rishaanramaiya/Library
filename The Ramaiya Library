// ----------------------------------------------
// Rendering helpers
// ----------------------------------------------

static void setColor(SDL_Renderer* r, Color c) {
    SDL_SetRenderDrawColor(r, c.r, c.g, c.b, c.a);
}

static void drawRect(SDL_Renderer* r, float x, float y, float w, float h, Color c) {
    SDL_Rect rc{static_cast<int>(x), static_cast<int>(y), static_cast<int>(w), static_cast<int>(h)};
    setColor(r, c);
    SDL_RenderFillRect(r, &rc);
}

static void drawOutline(SDL_Renderer* r, float x, float y, float w, float h, Color c) {
    SDL_Rect rc{static_cast<int>(x), static_cast<int>(y), static_cast<int>(w), static_cast<int>(h)};
    setColor(r, c);
    SDL_RenderDrawRect(r, &rc);
}

static void drawCircle(SDL_Renderer* r, int cx, int cy, int radius, Color c) {
    setColor(r, c);
    for (int y = -radius; y <= radius; ++y) {
        for (int x = -radius; x <= radius; ++x) {
            if (x * x + y * y <= radius * radius) {
                SDL_RenderDrawPoint(r, cx + x, cy + y);
            }
        }
    }
}

// ----------------------------------------------
// Font
