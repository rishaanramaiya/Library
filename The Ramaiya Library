struct Game {
    SDL_Window* window = nullptr;
    SDL_Renderer* renderer = nullptr;
    bool running = true;

    Font uiFont;

    Dungeon dungeon;
    Player player;
    Inventory inv;
    InputState input;
    Settings settings;

    std::vector<Enemy> enemies;
    std::vector<Item> items;
    std::vector<NPC> npcs;
    std::vector<Projectile> projectiles;
    NPC sohaan;
    bool sohaanActive = true;
    NPC alain;
    bool showShop = false;
    int shopSelected = 0;

    Rng rng;

    uint32_t lastTick = 0;
    float delta = 0.0f;

    bool showDialogue = false;
    std::string dialogueText;

    bool showInventory = false;

    bool win = false;
    int worldTier = 1;
    int baseRooms = 5;
    int procCount = 0;

    float fps = 0.0f;
    float fpsTimer = 0.0f;
    int fpsFrames = 0;

    std::string statusText;
    float statusTime = 0.0f;
    Color statusColor{220, 230, 240, 255};

    int worldSeed = 1;

    void setupDefaultBinds() {
        input.binds.keys[ActMoveUp] = SDL_SCANCODE_W;
        input.binds.keys[ActMoveDown] = SDL_SCANCODE_S;
        input.binds.keys[ActMoveLeft] = SDL_SCANCODE_A;
        input.binds.keys[ActMoveRight] = SDL_SCANCODE_D;
        input.binds.keys[ActAttack] = SDL_SCANCODE_SPACE;
        input.binds.keys[ActInteract] = SDL_SCANCODE_E;
        input.binds.keys[ActUseItem] = SDL_SCANCODE_X;
        input.binds.keys[ActDash] = SDL_SCANCODE_LSHIFT;
        input.binds.keys[ActLockOn] = SDL_SCANCODE_TAB;
        input.binds.keys[ActInvToggle] = SDL_SCANCODE_I;
        input.binds.keys[ActInvNext] = SDL_SCANCODE_R;
        input.binds.keys[ActInvPrev] = SDL_SCANCODE_F;
    }

    const char* actionName(Action a) const {
        switch (a) {
            case ActMoveUp: return "Move Up";
            case ActMoveDown: return "Move Down";
            case ActMoveLeft: return "Move Left";
            case ActMoveRight: return "Move Right";
            case ActAttack: return "Attack";
            case ActInteract: return "Interact";
            case ActUseItem: return "Use Item";
            case ActDash: return "Dash";
            case ActLockOn: return "Lock-On";
            case ActInvToggle: return "Inventory Toggle";
            case ActInvNext: return "Inventory Next";
            case ActInvPrev: return "Inventory Prev";
            default: return "Unknown";
        }
    }

    void openController() {
        if (input.padConnected) return;
        int count = SDL_NumJoysticks();
        for (int i = 0; i < count; ++i) {
            if (SDL_IsGameController(i)) {
                input.pad = SDL_GameControllerOpen(i);
                if (input.pad) {
                    input.padConnected = true;
                    return;
                }
            }
        }
    }

    void closeController() {
        if (input.pad) SDL_GameControllerClose(input.pad);
        input.pad = nullptr;
        input.padConnected = false;
    }

    std::string bindsPath() const {
        return "controls.cfg";
    }

    void pushStatus(const std::string& text, float seconds = 2.0f) {
        statusText = text;
        statusTime = seconds;
        statusColor = COLOR_TEXT;
    }

    void saveBinds() {
        std::ofstream out(bindsPath());
        if (!out) {
            pushStatus("Failed to save binds");
            return;
        }
        for (int i = 0; i < ActCount; ++i) {
            const char* name = actionName(static_cast<Action>(i));
            const char* keyName = SDL_GetScancodeName(input.binds.keys[i]);
            out << name << "=" << keyName << "\n";
        }
        pushStatus("Binds saved");
    }

    void loadBinds() {
        std::ifstream in(bindsPath());
        if (!in) {
            return;
        }
        std::string line;
        while (std::getline(in, line)) {
            size_t eq = line.find('=');
            if (eq == std::string::npos) continue;
            std::string name = line.substr(0, eq);
            std::string key = line.substr(eq + 1);
            SDL_Scancode sc = SDL_GetScancodeFromName(key.c_str());
            if (sc == SDL_SCANCODE_UNKNOWN) continue;
            for (int i = 0; i < ActCount; ++i) {
                if (name == actionName(static_cast<Action>(i))) {
                    input.binds.keys[i] = sc;
                }
            }
        }
        pushStatus("Binds loaded");
    }

    bool init() {
        if (SDL_Init(SDL_INIT_VIDEO | SDL_INIT_TIMER) != 0) return false;
        if (TTF_Init() != 0) return false;

        window = SDL_CreateWindow("Zelda-like SDL2", SDL_WINDOWPOS_CENTERED, SDL_WINDOWPOS_CENTERED, SCREEN_W, SCREEN_H, SDL_WINDOW_SHOWN);
        if (!window) return false;

        renderer = SDL_CreateRenderer(window, -1, SDL_RENDERER_ACCELERATED);
        if (!renderer) return false;

        // Use a common font path; user can change if needed.
        uiFont.init("C:/Windows/Fonts/arial.ttf", 16);

        setupDefaultBinds();
        loadBinds();
        openController();

        setupDungeon();
        setupRoomEntities();

        lastTick = tickMs();
        return true;
    }

    void shutdown() {
        uiFont.destroy();
        closeController();
        if (renderer) SDL_DestroyRenderer(renderer);
        if (window) SDL_DestroyWindow(window);
        TTF_Quit();
        SDL_Quit();
    }

    void setupDungeon() {
        dungeon.rooms.clear();
        worldSeed = worldTier * 1337 + rng.range(1, 999);

        Room r0;
        r0.id = 0;
        r0.name = "Forest Edge";
        r0.exits = {1, 1}; // dummy
        fillRoom(r0);
        carveDoors(r0, true, true, false, false);

        Room r1;
        r1.id = 1;
        r1.name = "Ancient Hall";
        r1.exits = {1, 1};
        fillRoom(r1);
        carveDoors(r1, true, false, true, true);
        addGate(r1, MAP_W - 2, MAP_H / 2);
        addSwitch(r1, 6, 12);

        Room r2;
        r2.id = 2;
        r2.name = "Underground Lake";
        r2.exits = {1, 1};
        fillRoom(r2);
        carveDoors(r2, false, true, true, false);
        addWater(r2);
        addGapPuzzle(r2);
        addCrackedWall(r2);

        Room r3;
        r3.id = 3;
        r3.name = "Boss Sanctuary";
        r3.exits = {1, 1};
        fillRoom(r3);
        carveDoors(r3, false, false, false, true);

        Room r4;
        r4.id = 4;
        r4.name = "Hidden Grove";
        r4.exits = {1, 1};
        fillRoom(r4);
        carveDoors(r4, true, false, false, false);

        dungeon.rooms.push_back(r0);
        dungeon.rooms.push_back(r1);
        dungeon.rooms.push_back(r2);
        dungeon.rooms.push_back(r3);
        dungeon.rooms.push_back(r4);

        procCount = clampi(worldTier, 0, 6);
        for (int i = 0; i < procCount; ++i) {
            bool first = (i == 0);
            bool last = (i == procCount - 1);
            addProceduralRoom(baseRooms + i, first, last);
        }
        if (procCount > 0) {
            dungeon.rooms[4].set(MAP_W / 2, MAP_H - 1, TileDoor);
        }

        dungeon.current = 0;
        player.pos = {TILE * 2.0f, TILE * 2.0f};
    }

    void fillRoom(Room& r) {
        for (int y = 0; y < MAP_H; ++y) {
            for (int x = 0; x < MAP_W; ++x) {
                if (x == 0 || y == 0 || x == MAP_W - 1 || y == MAP_H - 1) {
                    r.set(x, y, TileWall);
                } else {
                    r.set(x, y, TileFloor);
                }
            }
        }
        // Add some random obstacles
        for (int i = 0; i < 40; ++i) {
            int x = rng.range(2, MAP_W - 3);
            int y = rng.range(2, MAP_H - 3);
            r.set(x, y, TileWall);
        }
    }

    void carveDoors(Room& r, bool n, bool e, bool s, bool w) {
        if (n) {
            r.set(MAP_W / 2, 0, TileDoor);
        }
        if (s) {
            r.set(MAP_W / 2, MAP_H - 1, TileDoor);
        }
        if (e) {
            r.set(MAP_W - 1, MAP_H / 2, TileDoor);
        }
        if (w) {
            r.set(0, MAP_H / 2, TileDoor);
        }
    }

    void addWater(Room& r) {
        for (int y = 5; y < 10; ++y) {
            for (int x = 7; x < 17; ++x) {
                r.set(x, y, TileWater);
            }
        }
    }

    void addGapPuzzle(Room& r) {
        for (int x = 4; x < 12; ++x) {
            r.set(x, 7, TileGap);
        }
        r.set(8, 7, TilePillar);
    }

    void addCrackedWall(Room& r) {
        for (int y = 6; y < 10; ++y) {
            r.set(MAP_W - 2, y, TileCracked);
        }
    }

    void addGate(Room& r, int x, int y) {
        r.set(x, y, TileGate);
    }

    void addSwitch(Room& r, int x, int y) {
        r.set(x, y, TileSwitch);
    }

    void addProceduralRoom(int id, bool first, bool last) {
        Room r;
        r.id = id;
        r.name = "Wild Ruins " + std::to_string(id - baseRooms + 1);
        r.exits = {1, 1};
        fillRoom(r);

        bool west = true;
        bool east = true;
        if (first) west = true;
        if (last) east = false;

        carveDoors(r, false, east, false, west);

        // Tiered procedural puzzle layouts
        int roll = rng.range(0, 3);
        if (roll == 0) addWater(r);
        if (roll == 1) addGapPuzzle(r);
        if (roll == 2) addCrackedWall(r);
        if (roll == 3) {
            addGate(r, MAP_W - 2, MAP_H / 2);
            addSwitch(r, 6, 12);
        }

        if (worldTier >= 3 && rng.chance(0.4f)) {
            addGapPuzzle(r);
        }
        if (worldTier >= 4 && rng.chance(0.3f)) {
            addCrackedWall(r);
        }
        if (worldTier >= 5 && rng.chance(0.3f)) {
            addGate(r, MAP_W - 2, MAP_H / 2);
            addSwitch(r, 6, 12);
        }

        dungeon.rooms.push_back(r);
    }

    void setupRoomEntities() {
        enemies.clear();
        items.clear();
        npcs.clear();
        projectiles.clear();

        if (dungeon.current == 0) {
            enemies.push_back(makeEnemy(8, 8));
            enemies.push_back(makeEnemy(12, 10));
            items.push_back(makeItem("Rupee", 6, 6));
            items.push_back(makeItem("Potion", 18, 10));
            npcs.push_back(makeNPC(4, 12, {"Welcome, hero.", "Find the boss to the east!"}));
        } else if (dungeon.current == 1) {
            enemies.push_back(makeEnemy(6, 4));
            enemies.push_back(makeEnemy(18, 7));
            enemies.push_back(makeEnemy(14, 11));
            items.push_back(makeItem("Key", 3, 3));
            items.push_back(makeItem("Boomerang", 20, 12));
            npcs.push_back(makeNPC(10, 8, {"Beware the lake to the south.", "The boss awaits."}));
        } else if (dungeon.current == 2) {
            enemies.push_back(makeEnemy(5, 5));
            enemies.push_back(makeEnemy(19, 12));
            enemies.push_back(makeEnemy(10, 8));
            items.push_back(makeItem("Hookshot", 2, 12));
            items.push_back(makeItem("Rupee", 21, 4));
        } else if (dungeon.current == 3) {
            Enemy boss = makeEnemy(12, 8);
            boss.boss = true;
            boss.bossType = worldTier % 3;
            boss.hp = 18 + worldTier * 2;
            boss.maxHp = boss.hp;
            enemies.push_back(boss);
            items.push_back(makeItem("Triforce", 22, 12));
        } else if (dungeon.current == 4) {
            items.push_back(makeItem("Gloves", 6, 6));
            items.push_back(makeItem("Boots", 18, 10));
            addAlainTrader();
        } else if (dungeon.current >= baseRooms && dungeon.current < baseRooms + procCount) {
            IVec2 p1 = randomOpenTile();
            items.push_back(makeItem(randomUpgrade(), p1.x, p1.y));

            if (worldTier >= 2 && rng.chance(0.35f)) {
                IVec2 p2 = randomOpenTile();
                items.push_back(makeItem(randomUpgrade(), p2.x, p2.y));
            }

            if (worldTier >= 3 && rng.chance(0.15f)) {
                IVec2 p3 = randomOpenTile();
                items.push_back(makeItem(randomRelic(), p3.x, p3.y));
            }
        }

        addSohaanGuide();

        // Scale enemies per world tier
        for (int i = 0; i < worldTier / 2; ++i) {
            enemies.push_back(makeEnemy(6 + i, 6 + i));
        }
    }

    Enemy makeEnemy(int tx, int ty) {
        Enemy e;
        e.pos = {tx * TILE + TILE * 0.25f, ty * TILE + TILE * 0.25f};
        int base = 3 + (worldTier - 1);
        e.hp = base;
        e.maxHp = base;
        e.cooldown = rng.frange(0.0f, 2.0f);
        return e;
    }

    Item makeItem(const std::string& name, int tx, int ty) {
        Item it;
        it.name = name;
        it.pos = {tx * TILE + TILE * 0.25f, ty * TILE + TILE * 0.25f};
        if (name.rfind("Relic-", 0) == 0) it.rarity = 3;
        else if (name.rfind("Upgrade-", 0) == 0) it.rarity = 2;
        else if (name == "Hookshot" || name == "Boomerang" || name == "Gloves" || name == "Boots") it.rarity = 1;
        return it;
    }

    IVec2 randomOpenTile() {
        for (int tries = 0; tries < 200; ++tries) {
            int x = rng.range(2, MAP_W - 3);
            int y = rng.range(2, MAP_H - 3);
            int t = dungeon.cur().get(x, y);
            if (t == TileFloor) return {x, y};
        }
        return {2, 2};
    }

