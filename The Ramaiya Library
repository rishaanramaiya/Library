struct Font {
    TTF_Font* font = nullptr;
    bool init(const std::string& path, int size) {
        font = TTF_OpenFont(path.c_str(), size);
        return font != nullptr;
    }
    void destroy() {
        if (font) TTF_CloseFont(font);
        font = nullptr;
    }
};

static void drawText(SDL_Renderer* r, TTF_Font* font, int x, int y, const std::string& text, Color c) {
    if (!font) return;
    SDL_Color sc{c.r, c.g, c.b, c.a};
    SDL_Surface* surf = TTF_RenderText_Blended(font, text.c_str(), sc);
    if (!surf) return;
    SDL_Texture* tex = SDL_CreateTextureFromSurface(r, surf);
    SDL_Rect dst{x, y, surf->w, surf->h};
    SDL_FreeSurface(surf);
    if (tex) {
        SDL_RenderCopy(r, tex, nullptr, &dst);
        SDL_DestroyTexture(tex);
    }
}
