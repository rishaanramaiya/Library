// ----------------------------------------------
// Utility
// ----------------------------------------------

struct Vec2 {
    float x = 0.0f;
    float y = 0.0f;
};

struct IVec2 {
    int x = 0;
    int y = 0;
};

static float clampf(float v, float lo, float hi) {
    return (v < lo) ? lo : (v > hi) ? hi : v;
}

static int clampi(int v, int lo, int hi) {
    return (v < lo) ? lo : (v > hi) ? hi : v;
}

static float length(Vec2 v) {
    return std::sqrt(v.x * v.x + v.y * v.y);
}

static Vec2 normalize(Vec2 v) {
    float len = length(v);
    if (len <= 0.0001f) return {0, 0};
    return {v.x / len, v.y / len};
}

static float dist(Vec2 a, Vec2 b) {
    return length({a.x - b.x, a.y - b.y});
}

static IVec2 toTile(Vec2 p, int tileSize) {
    return {static_cast<int>(p.x) / tileSize, static_cast<int>(p.y) / tileSize};
}

static Vec2 toWorld(IVec2 t, int tileSize) {
    return {static_cast<float>(t.x * tileSize), static_cast<float>(t.y * tileSize)};
}

static uint32_t tickMs() {
    return SDL_GetTicks();
}

// ----------------------------------------------
// Random
// ----------------------------------------------

struct Rng {
    std::mt19937 gen;
    Rng() {
        std::random_device rd;
        gen.seed(rd());
    }
    int range(int lo, int hi) {
        std::uniform_int_distribution<int> d(lo, hi);
        return d(gen);
    }
    float frange(float lo, float hi) {
        std::uniform_real_distribution<float> d(lo, hi);
        return d(gen);
    }
    bool chance(float p) {
        std::bernoulli_distribution d(p);
        return d(gen);
    }
};

