enum TileType {
    TileFloor = 0,
    TileWall = 1,
    TileDoor = 2,
    TileWater = 3,
    TileGap = 4,
    TilePillar = 5,
    TileCracked = 6,
    TileGate = 7,
    TileSwitch = 8
};

struct Room {
    int id = 0;
    std::array<int, MAP_W * MAP_H> tiles{};
    std::string name;
    IVec2 exits; // bitmask NESW

    int get(int x, int y) const {
        if (x < 0 || y < 0 || x >= MAP_W || y >= MAP_H) return TileWall;
        return tiles[y * MAP_W + x];
    }
    void set(int x, int y, int v) {
        if (x < 0 || y < 0 || x >= MAP_W || y >= MAP_H) return;
        tiles[y * MAP_W + x] = v;
    }
};

struct Dungeon {
    std::vector<Room> rooms;
    int current = 0;

    Room& cur() { return rooms[current]; }
    const Room& cur() const { return rooms[current]; }
};

