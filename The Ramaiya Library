    }

    void updateSohaanFollow(float dt) {
        if (!sohaanActive) return;
        for (auto& n : npcs) {
            if (!n.isGuide) continue;
            float d = dist(player.pos, n.pos);
            if (d > TILE * 2.0f) {
                Vec2 dir = normalize({player.pos.x - n.pos.x, player.pos.y - n.pos.y});
                n.pos.x += dir.x * (PLAYER_SPEED * 0.6f) * dt;
                n.pos.y += dir.y * (PLAYER_SPEED * 0.6f) * dt;
            }
        }
    }

    bool isBlockedTile(int x, int y) {
        int t = dungeon.cur().get(x, y);
        if (t == TileWall) return true;
        if (t == TileWater) return true;
        if (t == TileGap) return true;
        if (t == TileGate) return true;
        return false;
    }

    bool isBlocked(Vec2 p) {
        IVec2 t = toTile(p, TILE);
        return isBlockedTile(t.x, t.y);
    }

    bool rectIntersects(Vec2 aPos, float aSize, Vec2 bPos, float bSize) {
        SDL_FRect a{aPos.x, aPos.y, aSize, aSize};
        SDL_FRect b{bPos.x, bPos.y, bSize, bSize};
        return SDL_HasIntersectionF(&a, &b);
    }

    bool actionKeyDown(const Uint8* keys, Action a) const {
        return keys[input.binds.keys[a]] != 0;
    }

    Vec2 getMovementInput(const Uint8* keys) const {
        Vec2 dir{0, 0};
        if (actionKeyDown(keys, ActMoveUp)) dir.y -= 1;
        if (actionKeyDown(keys, ActMoveDown)) dir.y += 1;
        if (actionKeyDown(keys, ActMoveLeft)) dir.x -= 1;
        if (actionKeyDown(keys, ActMoveRight)) dir.x += 1;

        if (input.padConnected && input.pad) {
            float ax = SDL_GameControllerGetAxis(input.pad, SDL_CONTROLLER_AXIS_LEFTX) / 32767.0f;
            float ay = SDL_GameControllerGetAxis(input.pad, SDL_CONTROLLER_AXIS_LEFTY) / 32767.0f;
            const float dead = 0.2f;
            if (std::abs(ax) > dead) dir.x = ax;
            if (std::abs(ay) > dead) dir.y = ay;
        }

        return normalize(dir);
    }

    void movePlayer(float dt, Vec2 dir) {
        player.vel = {dir.x * player.speed, dir.y * player.speed};

        Vec2 next = player.pos;
        next.x += player.vel.x * dt;
        next.y += player.vel.y * dt;

        if (!isBlocked(next)) {
            player.pos = next;
        }
    }

    void handleDoorTransition() {
        IVec2 t = toTile(player.pos, TILE);
        int tile = dungeon.cur().get(t.x, t.y);
        if (tile != TileDoor) return;

        // Simple mapping for 4 rooms
        if (dungeon.current == 0 && t.x == MAP_W / 2 && t.y == 0) {
            dungeon.current = 1;
            player.pos = {TILE * (MAP_W / 2.0f), TILE * (MAP_H - 2.0f)};
        } else if (dungeon.current == 0 && t.x == MAP_W - 1 && t.y == MAP_H / 2) {
            dungeon.current = 1;
            player.pos = {TILE * 2.0f, TILE * (MAP_H / 2.0f)};
        } else if (dungeon.current == 1 && t.y == MAP_H - 1) {
            dungeon.current = 2;
            player.pos = {TILE * (MAP_W / 2.0f), TILE * 2.0f};
        } else if (dungeon.current == 1 && t.x == 0) {
            dungeon.current = 0;
            player.pos = {TILE * (MAP_W - 2.0f), TILE * (MAP_H / 2.0f)};
        } else if (dungeon.current == 2 && t.y == 0) {
            dungeon.current = 1;
            player.pos = {TILE * (MAP_W / 2.0f), TILE * (MAP_H - 2.0f)};
        } else if (dungeon.current == 2 && t.x == MAP_W - 1) {
            dungeon.current = 3;
            player.pos = {TILE * 2.0f, TILE * (MAP_H / 2.0f)};
        } else if (dungeon.current == 3 && t.x == 0) {
            dungeon.current = 2;
            player.pos = {TILE * (MAP_W - 2.0f), TILE * (MAP_H / 2.0f)};
        } else if (dungeon.current == 2 && t.y == MAP_H - 1) {
            dungeon.current = 4;
            player.pos = {TILE * (MAP_W / 2.0f), TILE * 2.0f};
        } else if (dungeon.current == 4 && t.y == 0) {
            dungeon.current = 2;
            player.pos = {TILE * (MAP_W / 2.0f), TILE * (MAP_H - 2.0f)};
        } else if (dungeon.current == 4 && t.y == MAP_H - 1 && procCount > 0) {
            dungeon.current = baseRooms;
            player.pos = {TILE * 2.0f, TILE * (MAP_H / 2.0f)};
        } else if (dungeon.current >= baseRooms && dungeon.current < baseRooms + procCount) {
            int idx = dungeon.current - baseRooms;
            if (t.x == MAP_W - 1) {
                if (idx + 1 < procCount) {
                    dungeon.current += 1;
                    player.pos = {TILE * 2.0f, TILE * (MAP_H / 2.0f)};
                } else {
                    dungeon.current = 2;
                    player.pos = {TILE * 2.0f, TILE * (MAP_H / 2.0f)};
                }
            } else if (t.x == 0) {
                if (idx - 1 >= 0) {
                    dungeon.current -= 1;
                    player.pos = {TILE * (MAP_W - 2.0f), TILE * (MAP_H / 2.0f)};
                } else {
                    dungeon.current = 4;
                    player.pos = {TILE * (MAP_W / 2.0f), TILE * 2.0f};
                }
            }
        }

        setupRoomEntities();
    }

    Vec2 aimDirection() const {
        Vec2 center{player.pos.x + TILE * 0.3f, player.pos.y + TILE * 0.3f};
        Vec2 mouse{static_cast<float>(input.mouseX), static_cast<float>(input.mouseY)};
        Vec2 dir = {mouse.x - center.x, mouse.y - center.y};

        if (input.padConnected && input.pad) {
            float rx = SDL_GameControllerGetAxis(input.pad, SDL_CONTROLLER_AXIS_RIGHTX) / 32767.0f;
            float ry = SDL_GameControllerGetAxis(input.pad, SDL_CONTROLLER_AXIS_RIGHTY) / 32767.0f;
            const float dead = 0.2f;
            if (std::abs(rx) > dead || std::abs(ry) > dead) {
                dir = {rx, ry};
            }
        }

        return normalize(dir);
    }

    void startDash(Vec2 dir) {
        if (input.dashCooldown > 0.0f) return;
        if (length(dir) < 0.1f) return;
        input.dashTime = 0.12f;
        input.dashCooldown = 0.6f;
        input.dashDir = dir;
    }

    void updateDash(float dt) {
        if (input.dashCooldown > 0.0f) input.dashCooldown -= dt;
        if (input.dashTime > 0.0f) {
            input.dashTime -= dt;
            Vec2 next = player.pos;
            next.x += input.dashDir.x * player.speed * player.dashMult * dt;
            next.y += input.dashDir.y * player.speed * player.dashMult * dt;
            if (!isBlocked(next)) player.pos = next;
        }
    }

    void updateLockOn() {
        if (!input.lockOn) {
            input.lockTarget = -1;
            return;
        }
        float best = 999999.0f;
        int bestIdx = -1;
        for (size_t i = 0; i < enemies.size(); ++i) {
            if (enemies[i].hp <= 0) continue;
            float d = dist(player.pos, enemies[i].pos);
            if (d < best) {
                best = d;
                bestIdx = static_cast<int>(i);
            }
        }
        input.lockTarget = bestIdx;
    }

    void pickItems() {
        for (auto& it : items) {
            if (it.picked) continue;
            if (rectIntersects(player.pos, TILE * 0.5f, it.pos, TILE * 0.5f)) {
                it.picked = true;
                if (it.rarity == 1) statusColor = COLOR_RARE;
                if (it.rarity == 2) statusColor = COLOR_EPIC;
                if (it.rarity == 3) statusColor = COLOR_LEGEND;
                if (it.name == "Rupee") {
                    player.rupees += 1;
                    if (player.rupees % 5 == 0) player.attack += 1;
                } else if (it.name == "Heart") {
                    player.hp = clampi(player.hp + 1, 0, player.maxHp);
                } else if (it.name == "Potion") {
                    player.hp = clampi(player.hp + 2, 0, player.maxHp);
                } else if (it.name == "Key") {
                    player.keys += 1;
                } else if (it.name == "Triforce") {
                    win = true;
                    worldTier += 1;
                    pushStatus("Triforce claimed! World Tier " + std::to_string(worldTier));
                    // Reset room state but keep progression items
                    setupDungeon();
                    dungeon.current = 0;
                    setupRoomEntities();
                } else if (it.name == "Upgrade-HP") {
                    player.maxHp += 1;
                    player.hp = clampi(player.hp + 1, 0, player.maxHp);
                    pushStatus("Max HP +1");
                } else if (it.name == "Upgrade-ATK") {
                    player.attack += 1;
                    pushStatus("Attack +1");
                } else if (it.name == "Upgrade-Speed") {
                    player.speed += 10.0f;
                    pushStatus("Speed +");
                } else if (it.name == "Upgrade-Dash") {
                    player.dashMult += 0.2f;
                    pushStatus("Dash +");
                } else if (it.name == "Upgrade-Heart") {
                    player.maxHp += 2;
                    player.hp = clampi(player.hp + 2, 0, player.maxHp);
                    pushStatus("Max HP +2");
                } else if (it.name == "Relic-Sun") {
                    player.attack += 2;
                    player.maxHp += 2;
                    player.hp = clampi(player.hp + 2, 0, player.maxHp);
                    player.speed += 10.0f;
                    player.dashMult += 0.2f;
                    pushStatus("Relic of the Sun");
                } else if (it.name == "Relic-Storm") {
                    player.attack += 1;
                    player.speed += 20.0f;
                    player.dashMult += 0.4f;
                    pushStatus("Relic of the Storm");
                } else if (it.name == "Relic-Ocean") {
                    player.maxHp += 3;
                    player.hp = clampi(player.hp + 3, 0, player.maxHp);
                    pushStatus("Relic of the Ocean");
                } else {
                    inv.add(it.name);
                    pushStatus("Got " + it.name);
                }
            }
        }
    }

    void updateNPCs(const Uint8* keys) {
        if (actionKeyDown(keys, ActInteract)) {
            for (auto& n : npcs) {
                if (dist(player.pos, n.pos) < TILE) {
                    n.talking = true;
                    showDialogue = true;
                    if (n.isGuide) {
                        dialogueText = guidanceText();
                    } else if (n.isTrader) {
                        dialogueText = "Alain: Welcome to the shrine. Press E to trade.";
                        showShop = true;
                    } else {
                        dialogueText = n.lines[n.currentLine];
                    }
                    n.currentLine = (n.currentLine + 1) % static_cast<int>(n.lines.size());
                }
            }
        }
    }

    void handleAttacks(const Uint8* keys) {
        if (player.attackCooldown > 0.0f) return;
        bool fire = actionKeyDown(keys, ActAttack);
        if (input.mouseShoot) fire = true;
        if (input.padConnected && input.pad) {
            if (SDL_GameControllerGetButton(input.pad, SDL_CONTROLLER_BUTTON_RIGHTSHOULDER)) fire = true;
        }
        if (fire) {
            player.attackCooldown = 0.25f;
            Projectile p;
            p.pos = {player.pos.x + TILE * 0.25f, player.pos.y + TILE * 0.25f};
            Vec2 dir = aimDirection();
            if (length(dir) < 0.1f) dir = {1, 0};
            p.vel = {dir.x * PROJECTILE_SPEED, dir.y * PROJECTILE_SPEED};
            p.damage = player.attack;
            p.friendly = true;
            projectiles.push_back(p);
        }
    }

    bool hasItem(const std::string& name) const {
        for (const auto& it : inv.items) {
            if (it == name) return true;
        }
        return false;
    }

    void useUtilityItem(const Uint8* keys) {
        if (!actionKeyDown(keys, ActUseItem)) return;
        std::string cur = inv.current();
        if (cur.empty()) return;

        if (cur == "Boomerang") {
            Projectile p;
            p.pos = {player.pos.x + TILE * 0.25f, player.pos.y + TILE * 0.25f};
            Vec2 dir = aimDirection();
            if (length(dir) < 0.1f) dir = {1, 0};
            p.vel = {dir.x * PROJECTILE_SPEED * 0.8f, dir.y * PROJECTILE_SPEED * 0.8f};
            p.damage = 1;
            p.friendly = true;
            projectiles.push_back(p);
            pushStatus("Boomerang!");
        } else if (cur == "Hookshot") {
            Vec2 dir = aimDirection();
            if (length(dir) < 0.1f) return;
            // Ray forward for pillar
            for (int i = 1; i < 8; ++i) {
                Vec2 p = {player.pos.x + dir.x * TILE * i, player.pos.y + dir.y * TILE * i};
                IVec2 t = toTile(p, TILE);
                if (dungeon.cur().get(t.x, t.y) == TilePillar) {
                    player.pos = {t.x * TILE + 2.0f, t.y * TILE + 2.0f};
                    pushStatus("Hookshot!");
                    break;
                }
            }
        } else if (cur == "Gloves") {
            IVec2 t = toTile(player.pos, TILE);
            for (int dy = -1; dy <= 1; ++dy) {
                for (int dx = -1; dx <= 1; ++dx) {
                    if (dungeon.cur().get(t.x + dx, t.y + dy) == TileCracked) {
                        dungeon.cur().set(t.x + dx, t.y + dy, TileFloor);
                        pushStatus("Cracked wall broken");
                        return;
                    }
                }
            }
        } else if (cur == "Boots") {
            // Boots let you cross gaps by temporarily treating them as floor
            IVec2 t = toTile(player.pos, TILE);
            for (int dy = -1; dy <= 1; ++dy) {
                for (int dx = -1; dx <= 1; ++dx) {
                    if (dungeon.cur().get(t.x + dx, t.y + dy) == TileGap) {
                        dungeon.cur().set(t.x + dx, t.y + dy, TileFloor);
                    }
                }
            }
            pushStatus("Boots: path opened");
        }
    }

    void updateProjectiles(float dt) {
        for (auto& p : projectiles) {
            if (!p.alive) continue;
            p.pos.x += p.vel.x * dt;
            p.pos.y += p.vel.y * dt;
            IVec2 t = toTile(p.pos, TILE);
            if (dungeon.cur().get(t.x, t.y) == TileSwitch) {
                dungeon.cur().set(MAP_W - 2, MAP_H / 2, TileFloor);
                p.alive = false;
                pushStatus("Gate opened");
                continue;
            }
            if (isBlockedTile(t.x, t.y)) {
                p.alive = false;
                continue;
            }
            for (auto& e : enemies) {
                if (e.hp <= 0) continue;
                if (p.friendly && rectIntersects(p.pos, 8, e.pos, TILE * 0.5f)) {
                    e.hp -= p.damage;
                    p.alive = false;
                }
            }
        }
    }

    void updateEnemies(float dt) {
        for (auto& e : enemies) {
            if (e.hp <= 0) continue;

            float speed = e.boss ? (BOSS_SPEED + worldTier * 2.0f) : ENEMY_SPEED;
            Vec2 dir = normalize({player.pos.x - e.pos.x, player.pos.y - e.pos.y});

            e.pos.x += dir.x * speed * dt;
            e.pos.y += dir.y * speed * dt;

            if (dist(player.pos, e.pos) < TILE * 0.6f) {
                if (!player.invincible) {
                    player.hp -= e.boss ? 2 : 1;
                    player.invincible = true;
                    player.invincTime = 1.0f;
                    if (player.hp <= 0) {
                        running = false;
                    }
                }
            }

            // Boss fires projectiles
            if (e.boss) {
                e.cooldown -= dt;
                float cd = (e.bossType == 0) ? 1.0f : (e.bossType == 1 ? 0.7f : 0.5f);
                if (e.cooldown <= 0.0f) {
                    e.cooldown = cd;
                    Projectile p;
                    p.pos = {e.pos.x + TILE * 0.25f, e.pos.y + TILE * 0.25f};
                    Vec2 d = normalize({player.pos.x - e.pos.x, player.pos.y - e.pos.y});
                    p.vel = {d.x * PROJECTILE_SPEED * 0.8f, d.y * PROJECTILE_SPEED * 0.8f};
                    p.damage = 1;
                    p.friendly = false;
                    projectiles.push_back(p);

                    if (e.bossType == 2) {
                        // Triple shot spread
                        Vec2 d1 = normalize({d.x + 0.3f, d.y});
                        Vec2 d2 = normalize({d.x - 0.3f, d.y});
                        Projectile p1 = p;
                        Projectile p2 = p;
                        p1.vel = {d1.x * PROJECTILE_SPEED * 0.7f, d1.y * PROJECTILE_SPEED * 0.7f};
                        p2.vel = {d2.x * PROJECTILE_SPEED * 0.7f, d2.y * PROJECTILE_SPEED * 0.7f};
                        projectiles.push_back(p1);
                        projectiles.push_back(p2);
                    }
                }
            }
        }
    }

    void awardXp() {
        for (auto& e : enemies) {
            if (e.hp <= 0 && !e.rewarded) {
                int gain = e.boss ? (10 + worldTier * 2) : (2 + worldTier / 2);
                player.xp += gain;
                e.rewarded = true;
                pushStatus("XP +" + std::to_string(gain));
            }
        }
    }

    void updatePlayerInvincible(float dt) {
        if (player.invincible) {
            player.invincTime -= dt;
            if (player.invincTime <= 0.0f) {
                player.invincible = false;
            }
        }
        if (player.attackCooldown > 0.0f) {
            player.attackCooldown -= dt;
        }
    }

    void updateProjectilesHitPlayer() {
        for (auto& p : projectiles) {
            if (!p.alive || p.friendly) continue;
            if (rectIntersects(p.pos, 8, player.pos, TILE * 0.5f)) {
                p.alive = false;
                if (!player.invincible) {
                    player.hp -= p.damage;
                    player.invincible = true;
                    player.invincTime = 1.0f;
                    if (player.hp <= 0) running = false;
                }
            }
        }
    }

    void pruneDead() {
        for (auto& p : projectiles) {
            if (!p.alive) {
                p.pos = {-999, -999};
            }
        }
    }

    void updateFps(float dt) {
        fpsTimer += dt;
        fpsFrames += 1;
        if (fpsTimer >= 0.5f) {
            fps = fpsFrames / fpsTimer;
            fpsTimer = 0.0f;
            fpsFrames = 0;
        }
    }

    void updateStatus(float dt) {
        if (statusTime > 0.0f) {
            statusTime -= dt;
            if (statusTime <= 0.0f) {
                statusText.clear();
            }
        }
    }

    std::vector<std::pair<std::string, int>> shopItems() const {
        return {
            {"HP +1", 15 + worldTier * 2},
            {"Attack +1", 18 + worldTier * 2},
            {"Speed +10", 12 + worldTier},
            {"Dash +0.2", 14 + worldTier},
            {"Max HP +2", 24 + worldTier * 3}
        };
    }

    void buyShopItem(int idx) {
        auto items = shopItems();
        if (idx < 0 || idx >= static_cast<int>(items.size())) return;
        int cost = items[idx].second;
        if (player.xp < cost) {
            pushStatus("Not enough XP");
            return;
        }
        player.xp -= cost;
        switch (idx) {
            case 0: player.maxHp += 1; player.hp = clampi(player.hp + 1, 0, player.maxHp); break;
            case 1: player.attack += 1; break;
            case 2: player.speed += 10.0f; break;
            case 3: player.dashMult += 0.2f; break;
            case 4: player.maxHp += 2; player.hp = clampi(player.hp + 2, 0, player.maxHp); break;
            default: break;
        }
        pushStatus("Purchase complete");
    }

    void update(float dt) {
        const Uint8* keys = SDL_GetKeyboardState(nullptr);
        if (keys[SDL_SCANCODE_ESCAPE]) running = false;

        Vec2 dir = getMovementInput(keys);
        movePlayer(dt, dir);

        bool dashPressed = actionKeyDown(keys, ActDash);
        if (input.padConnected && input.pad) {
            if (SDL_GameControllerGetButton(input.pad, SDL_CONTROLLER_BUTTON_LEFTSHOULDER)) dashPressed = true;
        }
        if (dashPressed) startDash(dir);

        updateDash(dt);
        updateLockOn();

        handleDoorTransition();
        pickItems();
        updateNPCs(keys);
        updateSohaanFollow(dt);
        handleAttacks(keys);
        useUtilityItem(keys);
        updateEnemies(dt);
        awardXp();
        updateProjectiles(dt);
        updateProjectilesHitPlayer();
        updatePlayerInvincible(dt);
        pruneDead();
        updateFps(dt);
        updateStatus(dt);
    }
    void drawMap() {
        for (int y = 0; y < MAP_H; ++y) {
            for (int x = 0; x < MAP_W; ++x) {
                int t = dungeon.cur().get(x, y);
                Color c = COLOR_FLOOR;
                if (t == TileWall) c = COLOR_WALL;
                if (t == TileDoor) c = {120, 80, 40, 255};
                if (t == TileWater) c = {40, 70, 120, 255};
                if (t == TileGap) c = {10, 10, 20, 255};
                if (t == TilePillar) c = {160, 160, 180, 255};
                if (t == TileCracked) c = {120, 100, 80, 255};
                if (t == TileGate) c = {120, 60, 30, 255};
                if (t == TileSwitch) c = {80, 160, 80, 255};
                drawRect(renderer, x * TILE, y * TILE, TILE, TILE, c);
            }
        }
    }

    void drawPlayer() {
        Color c = COLOR_PLAYER;
        if (player.invincible && (static_cast<int>(tickMs() / 100) % 2 == 0)) {
            c = {255, 255, 255, 255};
        }
        drawRect(renderer, player.pos.x, player.pos.y, TILE * 0.6f, TILE * 0.6f, c);
    }

    void drawEnemies() {
        for (auto& e : enemies) {
            if (e.hp <= 0) continue;
            Color c = e.boss ? COLOR_BOSS : COLOR_ENEMY;
            drawRect(renderer, e.pos.x, e.pos.y, TILE * 0.6f, TILE * 0.6f, c);
            // HP bar
            float pct = static_cast<float>(e.hp) / static_cast<float>(e.maxHp);
            drawRect(renderer, e.pos.x, e.pos.y - 6, TILE * 0.6f * pct, 4, {220, 80, 80, 255});
        }
    }

    void drawLockOn() {
        if (!input.lockOn || input.lockTarget < 0) return;
        const Enemy& e = enemies[input.lockTarget];
        if (e.hp <= 0) return;
        drawOutline(renderer, e.pos.x - 4, e.pos.y - 4, TILE * 0.6f + 8, TILE * 0.6f + 8, {250, 240, 100, 255});
    }

    void drawItems() {
        for (auto& it : items) {
            if (it.picked) continue;
            Color c = COLOR_ITEM;
            if (it.rarity == 1) c = COLOR_RARE;
            if (it.rarity == 2) c = COLOR_EPIC;
            if (it.rarity == 3) c = COLOR_LEGEND;
            drawRect(renderer, it.pos.x, it.pos.y, TILE * 0.4f, TILE * 0.4f, c);
        }
    }

    void drawNPCs() {
        for (auto& n : npcs) {
            Color c = n.isGuide ? Color{240, 180, 80, 255} : COLOR_NPC;
            drawRect(renderer, n.pos.x, n.pos.y, TILE * 0.5f, TILE * 0.5f, c);
            if (n.isGuide) {
                drawText(renderer, uiFont.font, static_cast<int>(n.pos.x) - 6, static_cast<int>(n.pos.y) - 16, "Sohaan", COLOR_TEXT);
            }
            if (n.isTrader) {
                drawText(renderer, uiFont.font, static_cast<int>(n.pos.x) - 6, static_cast<int>(n.pos.y) - 16, "Alain", COLOR_TEXT);
            }
        }
    }

    void drawProjectiles() {
        for (auto& p : projectiles) {
            if (!p.alive) continue;
            drawCircle(renderer, static_cast<int>(p.pos.x), static_cast<int>(p.pos.y), 3, COLOR_PROJECTILE);
        }
    }

    void drawMinimap() {
        if (!settings.showMinimap) return;
        int miniSize = 4;
        int offsetX = SCREEN_W - (MAP_W * miniSize) - 10;
        int offsetY = 10;
        for (int y = 0; y < MAP_H; ++y) {
            for (int x = 0; x < MAP_W; ++x) {
                int t = dungeon.cur().get(x, y);
                Color c = (t == TileWall) ? Color{60, 80, 100, 255} : Color{30, 40, 50, 255};
                if (t == TileDoor) c = {120, 80, 40, 255};
                if (t == TileWater) c = {40, 70, 120, 255};
                if (t == TileGap) c = {10, 10, 20, 255};
                if (t == TilePillar) c = {160, 160, 180, 255};
                if (t == TileCracked) c = {120, 100, 80, 255};
                if (t == TileGate) c = {120, 60, 30, 255};
                if (t == TileSwitch) c = {80, 160, 80, 255};
                drawRect(renderer, offsetX + x * miniSize, offsetY + y * miniSize, miniSize, miniSize, c);
            }
        }
        IVec2 p = toTile(player.pos, TILE);
        drawRect(renderer, offsetX + p.x * miniSize, offsetY + p.y * miniSize, miniSize, miniSize, {220, 220, 140, 255});
    }

    void drawHelp() {
        if (!settings.showHelp) return;
        drawRect(renderer, 60, 60, SCREEN_W - 120, SCREEN_H - 120, {10, 10, 10, 230});
        drawOutline(renderer, 60, 60, SCREEN_W - 120, SCREEN_H - 120, {80, 120, 160, 255});
        drawText(renderer, uiFont.font, 80, 80, "Advanced Controls", COLOR_TEXT);
        int y = 110;
        for (int i = 0; i < ActCount; ++i) {
            std::string line = std::string(actionName(static_cast<Action>(i))) + ": " + SDL_GetScancodeName(input.binds.keys[i]);
            drawText(renderer, uiFont.font, 80, y, line, COLOR_TEXT);
            y += 18;
        }
        y += 8;
        drawText(renderer, uiFont.font, 80, y, "Mouse: aim with cursor, left click shoot, right click lock-on", COLOR_TEXT);
        y += 18;
        drawText(renderer, uiFont.font, 80, y, "Gamepad: left stick move, right stick aim, RB shoot, LB dash", COLOR_TEXT);
        y += 18;
        drawText(renderer, uiFont.font, 80, y, "F2 remap | F5 save binds | F9 load binds | F3 minimap | F4 FPS | F10 settings", COLOR_TEXT);
    }

    void drawStatus() {
        if (statusText.empty()) return;
        drawRect(renderer, 10, SCREEN_H - 50, 300, 30, {10, 10, 10, 210});
        drawOutline(renderer, 10, SCREEN_H - 50, 300, 30, {80, 120, 160, 255});
        drawText(renderer, uiFont.font, 20, SCREEN_H - 44, statusText, statusColor);
    }

    void drawSettings() {
        if (!settings.showSettings) return;
        drawRect(renderer, 120, 80, SCREEN_W - 240, SCREEN_H - 160, {12, 12, 12, 235});
        drawOutline(renderer, 120, 80, SCREEN_W - 240, SCREEN_H - 160, {80, 120, 160, 255});
        drawText(renderer, uiFont.font, 140, 100, "Settings", COLOR_TEXT);

        int y = 140;
        std::vector<std::string> lines = {
            std::string("Minimap: ") + (settings.showMinimap ? "On" : "Off"),
            std::string("FPS Counter: ") + (settings.showFps ? "On" : "Off"),
            std::string("FPS Cap: ") + std::to_string(settings.fpsCap),
            std::string("Music Volume: ") + std::to_string(settings.musicVolume),
            std::string("SFX Volume: ") + std::to_string(settings.sfxVolume)
        };
        for (int i = 0; i < static_cast<int>(lines.size()); ++i) {
            std::string line = lines[i];
            if (i == settings.selected) line = "> " + line;
            drawText(renderer, uiFont.font, 140, y, line, COLOR_TEXT);
            y += 22;
        }
        drawText(renderer, uiFont.font, 140, y + 10, "Use Up/Down to select, Left/Right to change", COLOR_TEXT);
        drawText(renderer, uiFont.font, 140, y + 30, "F10 to close", COLOR_TEXT);
    }

    void drawShop() {
        if (!showShop) return;
        drawRect(renderer, 140, 100, SCREEN_W - 280, SCREEN_H - 200, {12, 12, 12, 235});
        drawOutline(renderer, 140, 100, SCREEN_W - 280, SCREEN_H - 200, {80, 120, 160, 255});
        drawText(renderer, uiFont.font, 160, 120, "Alain's Mountain Shrine", COLOR_TEXT);
        drawText(renderer, uiFont.font, 160, 140, "XP: " + std::to_string(player.xp), COLOR_TEXT);

        auto items = shopItems();
        int y = 180;
        for (int i = 0; i < static_cast<int>(items.size()); ++i) {
            std::string line = items[i].first + " - " + std::to_string(items[i].second) + " XP";
            if (i == shopSelected) line = "> " + line;
            drawText(renderer, uiFont.font, 160, y, line, COLOR_TEXT);
            y += 22;
        }
        drawText(renderer, uiFont.font, 160, y + 8, "Enter to buy | Esc to close", COLOR_TEXT);
    }

    void drawGuidanceArrow() {
        Vec2 target = guidanceTarget();
        Vec2 center{player.pos.x + TILE * 0.3f, player.pos.y + TILE * 0.3f};
        Vec2 dir = normalize({target.x - center.x, target.y - center.y});
        if (length(dir) < 0.1f) return;

        Vec2 tip{center.x + dir.x * 24.0f, center.y + dir.y * 24.0f};
        Vec2 left{-dir.y, dir.x};
        Vec2 p1{tip.x, tip.y};
        Vec2 p2{tip.x - dir.x * 10.0f + left.x * 6.0f, tip.y - dir.y * 10.0f + left.y * 6.0f};
        Vec2 p3{tip.x - dir.x * 10.0f - left.x * 6.0f, tip.y - dir.y * 10.0f - left.y * 6.0f};

        setColor(renderer, {240, 200, 80, 255});
        SDL_RenderDrawLine(renderer, static_cast<int>(center.x), static_cast<int>(center.y), static_cast<int>(tip.x), static_cast<int>(tip.y));
        SDL_RenderDrawLine(renderer, static_cast<int>(p1.x), static_cast<int>(p1.y), static_cast<int>(p2.x), static_cast<int>(p2.y));
        SDL_RenderDrawLine(renderer, static_cast<int>(p2.x), static_cast<int>(p2.y), static_cast<int>(p3.x), static_cast<int>(p3.y));
        SDL_RenderDrawLine(renderer, static_cast<int>(p3.x), static_cast<int>(p3.y), static_cast<int>(p1.x), static_cast<int>(p1.y));
    }

    void drawWorldMap() {
        if (!settings.showWorldMap) return;
        drawRect(renderer, 40, 40, SCREEN_W - 80, SCREEN_H - 80, {8, 8, 12, 235});
        drawOutline(renderer, 40, 40, SCREEN_W - 80, SCREEN_H - 80, {80, 120, 160, 255});
        drawText(renderer, uiFont.font, 60, 60, "World Map (Tier " + std::to_string(worldTier) + ")", COLOR_TEXT);
        drawText(renderer, uiFont.font, 60, 80, "Seed: " + std::to_string(worldSeed), COLOR_TEXT);

        int startX = 80;
        int startY = 140;
        int stepX = 80;

        auto roomLabel = [&](int id) {
            if (id == 0) return std::string("Start");
            if (id == 1) return std::string("Hall");
            if (id == 2) return std::string("Lake");
            if (id == 3) return std::string("Boss");
            if (id == 4) return std::string("Grove");
            return std::string("Ruins");
        };

        for (int i = 0; i < baseRooms + procCount; ++i) {
            int x = startX + i * stepX;
            int y = startY;
            Color c = (i == dungeon.current) ? Color{220, 220, 140, 255} : Color{120, 160, 200, 255};
            drawRect(renderer, x, y, 40, 20, c);
            drawText(renderer, uiFont.font, x + 4, y + 2, roomLabel(i), COLOR_BG);
            if (i + 1 < baseRooms + procCount) {
                drawRect(renderer, x + 40, y + 8, 40, 4, {80, 120, 160, 255});
            }
        }
        drawText(renderer, uiFont.font, 60, 200, "Procedural puzzle layouts scale with tier.", COLOR_TEXT);
    }

    void drawHUD() {
        int x = 10;
        int y = 10;
        for (int i = 0; i < player.maxHp; ++i) {
            Color c = (i < player.hp) ? Color{220, 80, 80, 255} : Color{80, 80, 80, 255};
            drawRect(renderer, x + i * 18, y, 14, 14, c);
        }
        drawText(renderer, uiFont.font, 10, 30, "Rupees: " + std::to_string(player.rupees), COLOR_HUD);
        drawText(renderer, uiFont.font, 10, 50, "Attack: " + std::to_string(player.attack), COLOR_HUD);
        drawText(renderer, uiFont.font, 10, 70, "Keys: " + std::to_string(player.keys), COLOR_HUD);
        drawText(renderer, uiFont.font, 10, 90, "Room: " + dungeon.cur().name, COLOR_HUD);
        drawText(renderer, uiFont.font, 10, 130, "World Tier: " + std::to_string(worldTier), COLOR_HUD);
        drawText(renderer, uiFont.font, 10, 150, "XP: " + std::to_string(player.xp), COLOR_HUD);
        drawText(renderer, uiFont.font, 10, 170, "Speed: " + std::to_string(static_cast<int>(player.speed)), COLOR_HUD);
        if (settings.showFps) {
            drawText(renderer, uiFont.font, 10, 110, "FPS: " + std::to_string(static_cast<int>(fps)), COLOR_HUD);
        }

        if (showInventory) {
            drawRect(renderer, 600, 10, 330, 120, {20, 20, 20, 220});
            drawOutline(renderer, 600, 10, 330, 120, {80, 120, 160, 255});
            drawText(renderer, uiFont.font, 610, 20, "Inventory", COLOR_TEXT);
            int iy = 45;
            for (size_t i = 0; i < inv.items.size(); ++i) {
                std::string line = inv.items[i];
                if (static_cast<int>(i) == inv.selected) line = "> " + line;
                drawText(renderer, uiFont.font, 610, iy, line, COLOR_TEXT);
                iy += 18;
            }
            if (inv.items.empty()) {
                drawText(renderer, uiFont.font, 610, 45, "(empty)", COLOR_TEXT);
            }
        }

        if (showDialogue) {
            drawRect(renderer, 80, SCREEN_H - 120, SCREEN_W - 160, 90, {10, 10, 10, 230});
            drawOutline(renderer, 80, SCREEN_H - 120, SCREEN_W - 160, 90, {120, 180, 220, 255});
            drawText(renderer, uiFont.font, 100, SCREEN_H - 100, dialogueText, COLOR_TEXT);
        }

        drawText(renderer, uiFont.font, 10, SCREEN_H - 22, "F1 help | F2 remap | F3 minimap | F4 FPS | F5 save binds | F6 map | F9 load binds | F10 settings | X use item", {160, 180, 200, 255});
    }

    void render() {
        setColor(renderer, COLOR_BG);
        SDL_RenderClear(renderer);

        drawMap();
        drawItems();
        drawNPCs();
        drawEnemies();
        drawProjectiles();
        drawPlayer();
        drawLockOn();
        drawGuidanceArrow();
        drawMinimap();
        drawHUD();
        drawStatus();
        drawHelp();
        drawSettings();
        drawWorldMap();
        drawShop();

        SDL_RenderPresent(renderer);
    }

    void gameLoop() {
        while (running) {
            uint32_t now = tickMs();
            delta = (now - lastTick) / 1000.0f;
            lastTick = now;

            // Cap delta for stability
            if (delta > 0.05f) delta = 0.05f;

            SDL_Event ev;
            while (SDL_PollEvent(&ev)) {
                if (ev.type == SDL_QUIT) running = false;
                if (ev.type == SDL_MOUSEMOTION) {
                    input.mouseX = ev.motion.x;
                    input.mouseY = ev.motion.y;
                }
                if (ev.type == SDL_MOUSEBUTTONDOWN) {
                    if (ev.button.button == SDL_BUTTON_LEFT) input.mouseShoot = true;
                    if (ev.button.button == SDL_BUTTON_RIGHT) input.lockOn = !input.lockOn;
                }
                if (ev.type == SDL_MOUSEBUTTONUP) {
                    if (ev.button.button == SDL_BUTTON_LEFT) input.mouseShoot = false;
                }
                if (ev.type == SDL_CONTROLLERDEVICEADDED) {
                    openController();
                }
                if (ev.type == SDL_CONTROLLERDEVICEREMOVED) {
                    closeController();
                }
                if (ev.type == SDL_KEYDOWN && input.remapMode) {
                    input.binds.keys[input.remapIndex] = ev.key.keysym.scancode;
                    input.remapIndex++;
                    if (input.remapIndex >= ActCount) {
                        input.remapMode = false;
                        input.remapIndex = 0;
                        pushStatus("Remap complete");
                    }
                }
                if (ev.type == SDL_KEYDOWN && !ev.key.repeat) {
                    SDL_Scancode sc = ev.key.keysym.scancode;
                    if (sc == SDL_SCANCODE_I) showInventory = !showInventory;
                    if (sc == SDL_SCANCODE_R) inv.next();
                    if (sc == SDL_SCANCODE_F) inv.prev();
                    if (sc == SDL_SCANCODE_TAB) input.lockOn = !input.lockOn;
                    if (sc == SDL_SCANCODE_F1) settings.showHelp = !settings.showHelp;
                    if (sc == SDL_SCANCODE_F10) settings.showSettings = !settings.showSettings;
                    if (sc == SDL_SCANCODE_F6) settings.showWorldMap = !settings.showWorldMap;
                    if (sc == SDL_SCANCODE_F2) {
                        input.remapMode = true;
                        input.remapIndex = 0;
                        pushStatus("Remap: press keys for each action");
                    }
                    if (sc == SDL_SCANCODE_F3) settings.showMinimap = !settings.showMinimap;
                    if (sc == SDL_SCANCODE_F4) settings.showFps = !settings.showFps;
                    if (sc == SDL_SCANCODE_F5) saveBinds();
                    if (sc == SDL_SCANCODE_F9) loadBinds();
                    if (sc == SDL_SCANCODE_ESCAPE && input.remapMode) {
                        input.remapMode = false;
                        input.remapIndex = 0;
                        pushStatus("Remap canceled");
                    }
                    if (showShop) {
                        if (sc == SDL_SCANCODE_UP) shopSelected = (shopSelected - 1 + 5) % 5;
                        if (sc == SDL_SCANCODE_DOWN) shopSelected = (shopSelected + 1) % 5;
                        if (sc == SDL_SCANCODE_RETURN) buyShopItem(shopSelected);
                        if (sc == SDL_SCANCODE_ESCAPE) showShop = false;
                    }
                    if (settings.showSettings) {
                        if (sc == SDL_SCANCODE_UP) settings.selected = (settings.selected - 1 + 5) % 5;
                        if (sc == SDL_SCANCODE_DOWN) settings.selected = (settings.selected + 1) % 5;
                        if (sc == SDL_SCANCODE_LEFT) {
                            if (settings.selected == 0) settings.showMinimap = !settings.showMinimap;
                            if (settings.selected == 1) settings.showFps = !settings.showFps;
                            if (settings.selected == 2) settings.fpsCap = 60;
                            if (settings.selected == 3) settings.musicVolume = clampi(settings.musicVolume - 10, 0, 100);
                            if (settings.selected == 4) settings.sfxVolume = clampi(settings.sfxVolume - 10, 0, 100);
                        }
                        if (sc == SDL_SCANCODE_RIGHT) {
                            if (settings.selected == 0) settings.showMinimap = !settings.showMinimap;
                            if (settings.selected == 1) settings.showFps = !settings.showFps;
                            if (settings.selected == 2) settings.fpsCap = (settings.fpsCap == 60) ? 120 : (settings.fpsCap == 120 ? 300 : 60);
                            if (settings.selected == 3) settings.musicVolume = clampi(settings.musicVolume + 10, 0, 100);
                            if (settings.selected == 4) settings.sfxVolume = clampi(settings.sfxVolume + 10, 0, 100);
                        }
                    }
                }
            }

            (void)0;

            update(delta);
            render();

            // 300 FPS cap
            uint32_t frameMs = tickMs() - now;
            int cap = settings.fpsCap;
            if (cap < 30) cap = 30;
            uint32_t targetMs = 1000 / static_cast<uint32_t>(cap);
            if (frameMs < targetMs) {
                SDL_Delay(targetMs - frameMs);
            }
        }
    }
};

